# Public site URL — must match a domain allowlisted in https://dashboard.reown.com
NEXT_PUBLIC_APP_URL=https://ppp-pt.vercel.app

# WalletConnect / Reown project ID — public, but keep out of git; set in Vercel too
# Create at https://dashboard.reown.com and allowlist your domain under Project Domains
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here
